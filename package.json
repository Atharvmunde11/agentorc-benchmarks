{
  "name": "wolbarg-benchmarks",
  "version": "2.0.0",
  "private": false,
  "description": "Public, reproducible dual-backend (SQLite + PostgreSQL) benchmarks for Wolbarg v0.2.1",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "benchmark": "tsx bench/index.ts",
    "benchmark:quick": "tsx bench/index.ts --quick",
    "benchmark:live": "tsx bench/index.ts --live",
    "charts": "tsx bench/charts.ts",
    "report": "tsx bench/index.ts --report-only"
  },
  "dependencies": {
    "wolbarg": "^0.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "dotenv": "^17.4.2",
    "sharp": "^0.34.2",
    "tinybench": "^6.0.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Atharvmunde11/wolbarg-benchmarks.git"
  },
  "bugs": {
    "url": "https://github.com/Atharvmunde11/wolbarg-benchmarks/issues"
  },
  "homepage": "https://wolbarg.com/benchmarks"
}
